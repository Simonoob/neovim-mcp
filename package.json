{
  "name": "neovim-mcp",
  "version": "0.1.0",
  "description": "MCP server for structured code navigation via Neovim's treesitter and LSP",
  "type": "module",
  "bin": {
    "neovim-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "bundle-lua": "luabundler bundle ./src/lua/index.lua -o ./build/lua/index.lua -p \"./?.lua\"",
    "copy-lua": "mkdir build && cp -r src/lua build/lua",
    "build": "rm -rf build && npm run copy-lua && npm run bundle-lua && tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "test": "NVIM_SOCKET_PATH=/tmp/nvim-mcp-test vitest run",
    "test:watch": "npm run test -- --watch"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "neovim": "^5.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "luabundler": "^1.2.3",
    "typescript": "^5.9.2",
    "vitest": "^4.1.4"
  }
}
